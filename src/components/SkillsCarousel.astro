---
const skills = [
  { name: 'Go', logo: 'https://cdn.simpleicons.org/go/00ADD8' },
  { name: 'AWS', logo: 'https://cdn.simpleicons.org/amazonaws/FF9900' },
  { name: 'Kubernetes', logo: 'https://cdn.simpleicons.org/kubernetes/326CE5' },
  { name: 'PostgreSQL', logo: 'https://cdn.simpleicons.org/postgresql/4169E1' },
  { name: 'ReactJS', logo: 'https://cdn.simpleicons.org/react/61DAFB' },
  { name: 'Redux', logo: 'https://cdn.simpleicons.org/redux/764ABC' },
  { name: 'Redux-Saga', logo: 'https://cdn.simpleicons.org/reduxsaga/999999' },
  { name: 'Next JS', logo: 'https://cdn.simpleicons.org/nextdotjs/FFFFFF' },
  { name: 'JavaScript', logo: 'https://cdn.simpleicons.org/javascript/F7DF1E' },
  { name: 'Material UI', logo: 'https://cdn.simpleicons.org/mui/007FFF' },
];
---

<section class="skills-spotlight card" aria-labelledby="skills-spotlight-title">
  <div class="section-heading">
    <h2 id="skills-spotlight-title">Skill Spotlight</h2>
  </div>

  <div class="skills-carousel" aria-live="polite">
    <img id="skill-logo" src={skills[0].logo} alt={skills[0].name} />
    <p id="skill-name">{skills[0].name}</p>
  </div>

  <script define:vars={{ skills }} is:inline>
    const logo = document.getElementById('skill-logo');
    const name = document.getElementById('skill-name');
    let index = 0;

    const rotate = () => {
      index = (index + 1) % skills.length;
      const next = skills[index];
      logo.classList.add('is-fading');
      setTimeout(() => {
        logo.src = next.logo;
        logo.alt = next.name;
        name.textContent = next.name;
        logo.classList.remove('is-fading');
      }, 220);
    };

    setInterval(rotate, 1800);
  </script>
</section>
